async function main(){if(!/(\.|^)verizon\.com$/i.test(location.hostname)){alert('Open a Verizon.com page first.');return}let urls=ask().map(vz);if(!urls.length){alert('No URLs provided.');return}console.clear();let rows=[],plans=[],total=0;for(let i=0;i<urls.length;i++){try{let p=await detectPlan(urls[i],i,urls.length);plans.push(p);total+=p.storages.length*p.colors.length}catch(e){rows.push({'Scanned At':new Date().toISOString(),'Product URL':urls[i],'Device':'Unknown','Storage':'N/A','Color':'N/A','Availability':'Error','Evidence':'Detection failed: '+(e.message||e)})}}let c=0;for(const p of plans){for(const s of p.storages){for(const col of p.colors){let row=await scanCombo(p,s,col,c,total);rows.push(row);console.log(row);c++}}}download(rows);console.table(rows);prog.done(`Complete. Exported ${rows.length} row(s).`,`URLs: ${urls.length}\nCombos: ${c}/${total}\nCSV downloaded.`);alert(`Scan complete. Rows exported: ${rows.length}. CSV downloaded.`)}
