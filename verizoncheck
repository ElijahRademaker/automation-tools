async function detectPlan(url,i,n){prog.set({status:`Detecting ${i+1}/${n}`,details:url});let f=await frame(url),d=doc(f);try{let dev=deviceName(d),storages=storagePlan(d);if(!storages.length)storages=[{index:0,label:'N/A',outOfStock:false,disabled:false,rawText:''}];f.remove();let colors=await detectColors(url);log('Detected',dev,{storages,colors});console.group(`Detected ${dev}`);console.log('storages',storages);console.log('colors',colors);console.groupEnd();return{url,device:dev,storages,colors}}catch(e){try{f.remove()}catch{}throw e}}
