async function frame(url){return new Promise((res,rej)=>{let f=document.createElement('iframe');f.style.cssText='position:fixed;left:-99999px;top:0;width:1500px;height:1700px;opacity:0;pointer-events:none';let t=setTimeout(()=>{f.remove();rej(Error('Timed out loading '+url))},CFG.timeout);f.onload=async()=>{clearTimeout(t);await sleep(CFG.hydrate);res(f)};f.src=url;document.body.appendChild(f)})}
