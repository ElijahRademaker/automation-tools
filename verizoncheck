function swatchLike(el){let r=rect(el);return r.w>=5&&r.h>=5&&r.w<=220&&r.h<=190}
function colorSignal(el){let s=directText(el)||deep(el);if(/\b\d+\s*(gb|tb)\b/i.test(s))return false;if(badNonOption(s.replace(oosRe,'')))return false;return knownColor(s)||/color|swatch|out\s*of\s*stock/i.test(s)||['button','label','input'].includes(el.tagName.toLowerCase())||low(el.getAttribute?.('role')||'')==='radio'}
function findColorControls(d){let b=bounds(d);if(b.colorTop==null||b.colorBottom==null)return[];let raw=controls(d).filter(el=>inY(el,b.colorTop,b.colorBottom)).filter(swatchLike).filter(colorSignal);let out=[],seen=new Set();for(const el of raw){let r=rect(el),key=`${Math.round(r.cx/7)*7}:${Math.round(r.cy/7)*7}`;if(!seen.has(key)){seen.add(key);out.push(el)}}return out.sort((a,b)=>Math.abs(rect(a).cy-rect(b).cy)>12?rect(a).cy-rect(b).cy:rect(a).cx-rect(b).cx)}
async function click(el){if(!el||!visible(el)||isElementOosSpecific(el)||isDisabledSpecific(el))return false;let r=rect(el);if(r.w>570||r.h>250)return false;el.scrollIntoView({block:'center',inline:'center'});await sleep(150);if(el.tagName.toLowerCase()==='option'){let s=el.closest('select');if(!s)return false;s.value=el.value;s.dispatchEvent(new Event('input',{bubbles:true}));s.dispatchEvent(new Event('change',{bubbles:true}))}else{try{el.dispatchEvent(new PointerEvent('pointerdown',{bubbles:true}))}catch{}el.dispatchEvent(new MouseEvent('mousedown',{bubbles:true}));el.click();el.dispatchEvent(new MouseEvent('mouseup',{bubbles:true}));try{el.dispatchEvent(new PointerEvent('pointerup',{bubbles:true}))}catch{}}await sleep(CFG.afterClick);return true}
async function detectColors(url){let f=await frame(url),d=doc(f);try{let sw=findColorControls(d);if(!sw.length)return[{index:0,label:selectedColor(d)||'N/A',outOfStock:false,disabled:false,rawText:''}];let colors=[];for(let i=0;i<sw.length;i++){sw=findColorControls(d);let el=sw[i],raw=directText(el)||deep(el),name=knownColor(raw)||`Color ${i+1}`,oos=isElementOosSpecific(el);if(!oos&&el){await click(el);await sleep(350);name=selectedColor(d)||knownColor(raw)||name}colors.push({index:i,label:name,outOfStock:oos,disabled:oos||isDisabledSpecific(el),rawText:raw})}let seen=new Set(),dedup=[];for(let c of colors){let key=c.label.toLowerCase();if(!seen.has(key)||/^color \d+$/i.test(c.label)){seen.add(key);dedup.push(c)}}return dedup}finally{f.remove()}}
function stockFromPage(d,storage,color,storageEl,colorEl){
