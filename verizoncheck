function makeUi(){const old=document.getElementById('vz-progress-v4');if(old)old.remove();let d=document.createElement('div');d.id='vz-progress-v4';d.style.cssText='position:fixed;right:18px;bottom:18px;z-index:2147483647;background:#111;color:white;width:480px;max-width:calc(100vw - 36px);padding:14px;border-radius:12px;font-family:Arial,sans-serif;font-size:13px;box-shadow:0 8px 28px #0008';d.innerHTML='<b>Verizon Availability Scanner v4</b><div id=s style="margin:8px 0;color:#eee">Starting...</div><div style="height:10px;background:#333;border-radius:99px;overflow:hidden"><div id=b style="height:100%;width:0;background:#0af"></div></div><pre id=p style="white-space:pre-wrap;color:#bbb;font:12px Arial;margin:8px 0 0"></pre><button id=h style="margin-top:8px;background:#333;color:#fff;border:1px solid #555;border-radius:6px;padding:4px 8px">Hide</button>';document.body.appendChild(d);d.querySelector('#h').onclick=()=>d.style.display='none';return{set(o={}){if(Number.isFinite(o.percent))d.querySelector('#b').style.width=Math.max(0,Math.min(100,o.percent))+'%';if(o.status!=null)d.querySelector('#s').textContent=o.status;if(o.details!=null)d.querySelector('#p').textContent=o.details},done(m,x){this.set({percent:100,status:m,details:x})}}}const prog=makeUi();
function ask(){let def=/(\.|^)verizon\.com$/i.test(location.hostname)?location.href:'';let x=prompt('Paste Verizon product URLs. Separate multiple URLs with commas or new lines.',def);return x?x.split(/[\n,]+/).map(s=>s.trim()).filter(Boolean).filter((u,i,a)=>a.indexOf(u)===i).slice(0,CFG.maxUrls):[]}
